{
	"compilerOptions": {
		"target": "ES2022",
		"module": "CommonJS",
		"lib": ["ES2022", "DOM"],
		"moduleResolution": "Node",
        "ignoreDeprecations": "6.0",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"types": ["node", "playwright/test"],
		"baseUrl": ".",
		"paths": {
			"@pages/*": ["pages/*"],
			"@tests/*": ["tests/*"],
			"@testdata/*": ["testdata/*"]
		}
	},
	"include": ["tests/**/*.ts", "pages/**/*.ts", "testdata/**/*.ts", "**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
